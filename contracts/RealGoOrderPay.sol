// File contracts/RealGoOrderPay.sol

// Original license: SPDX_License_Identifier: MIT
pragma solidity ^0.8.20;

interface INonStandardERC20 {
    function balanceOf(address account) external view returns (uint);
}

contract RealGoOrderPay is Ownable, ReentrancyGuard {
    using SafeERC20 for IERC20;

    mapping(bytes32 => bool) public paidOrders;
    mapping(address => bool) public allowedTokens;
    address[] public tokenList;
    bool public nativeAllowed;
    address public submitter;

    address public immutable treasury;

    event OrderPaid(
        string orderId,
        string paymentId,
        address indexed payer,
        address token,
        uint256 amount
    );
    event TokenAllowed(address token, bool allowed, uint256 timestamp);
    event NativeAllowedUpdated(bool allowed, uint256 timestamp);
    event SubmitterUpdated(address submitter, uint256 timestamp);

    constructor(address initialOwner, address _treasury, address _submitter) Ownable(initialOwner) {
        require(_treasury != address(0), "Invalid treasury");
        treasury = _treasury;
        submitter = _submitter;
    }

    // ------------------------
    // Admin
    // ------------------------

    function setNativeAllowed(bool allowed) external onlyOwner {
        nativeAllowed = allowed;
        emit NativeAllowedUpdated(allowed, block.timestamp);
    }

    function addToken(address token) external onlyOwner {
        require(token != address(0), "Invalid token");
        require(!allowedTokens[token], "Token already allowed");
        allowedTokens[token] = true;
        tokenList.push(token);
        emit TokenAllowed(token, true, block.timestamp);
    }

    function removeToken(address token) external onlyOwner {
        require(token != address(0), "Invalid token");
        require(allowedTokens[token], "Token not in whitelist");
        allowedTokens[token] = false;
        emit TokenAllowed(token, false, block.timestamp);
    }

    function setSubmitter(address _submitter) external onlyOwner {
        require(_submitter != address(0), "Invalid submitter");
        submitter = _submitter;
        emit SubmitterUpdated(_submitter, block.timestamp);
    }

    // ------------------------
    // Payments
    // ------------------------

    function payOrderERC20(
        string calldata orderId,
        string calldata paymentId,
        address token,
        uint256 amount,
        bytes calldata signature
    ) external nonReentrant {
        require(amount > 0 && amount < type(uint256).max / 2, "Invalid amount");
        require(token != address(0), "Invalid token");
        require(allowedTokens[token], "Token not allowed");

        uint256 chainId;
        assembly { chainId := chainid() }
        bytes32 messageHash = keccak256(abi.encodePacked(chainId, orderId, paymentId, token, amount));
        address signer = ECDSA.recover(messageHash, signature);
        require(signer == submitter, "Invalid signature");

        require(IERC20(token).allowance(msg.sender, address(this)) >= amount, "Insufficient allowance");

        bytes32 key = keccak256(abi.encodePacked(orderId, paymentId));
        require(!paidOrders[key], "Order already paid");

        paidOrders[key] = true;

        IERC20(token).safeTransferFrom(msg.sender, treasury, amount);

        emit OrderPaid(orderId, paymentId, msg.sender, token, amount);
    }

    function payOrderNative(
        string calldata orderId,
        string calldata paymentId,
        bytes calldata signature
    ) external payable nonReentrant {
        require(nativeAllowed, "Native not allowed");
        require(msg.value > 0 && msg.value < type(uint256).max / 2, "Invalid amount");

        // verify signature
        uint256 chainId;
        assembly { chainId := chainid() }
        bytes32 messageHash = keccak256(abi.encodePacked(chainId, orderId, paymentId, msg.value));
        address signer = ECDSA.recover(messageHash, signature);
        require(signer == submitter, "Invalid signature");

        bytes32 key = keccak256(abi.encodePacked(orderId, paymentId));
        require(!paidOrders[key], "Order already paid");

        paidOrders[key] = true;

        (bool success, ) = payable(treasury).call{value: msg.value}("");
        require(success, "Native transfer failed");

        emit OrderPaid(orderId, paymentId, msg.sender, address(0), msg.value);
    }

    // ------------------------
    // Rescue functions
    // ------------------------

    function rescueToken(address token, uint256 amount) external onlyOwner {
        require(token != address(0), "Invalid token");
        IERC20(token).safeTransfer(treasury, amount);
    }

    function rescueNative(uint256 amount) external onlyOwner {
        (bool success, ) = payable(treasury).call{value: amount}("");
        require(success, "Native transfer failed");
    }

    // ------------------------
    // Views
    // ------------------------

    function isPaid(
        string calldata orderId,
        string calldata paymentId
    ) external view returns (bool) {
        bytes32 key = keccak256(abi.encodePacked(orderId, paymentId));
        return paidOrders[key];
    }

    function getAllowedTokens() external view returns (address[] memory) {
        return tokenList;
    }

    // ------------------------
    // Fallbacks
    // ------------------------

    receive() external payable {
        revert("Use payOrderNative");
    }

    fallback() external payable {
        revert("Unsupported call");
    }
}
